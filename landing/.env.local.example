# Full public URL of the static site (include NEXT_PUBLIC_BASE_PATH if you use one).
# Used for SEO metadata and verification links.
NEXT_PUBLIC_APP_URL=https://www.goalsguild.com

# Keep empty for root hosting (for example, CloudFront default domain).
# Set only when serving under a path prefix.
NEXT_PUBLIC_BASE_PATH=

# Public browser endpoint used by checkout and trial pages.
NEXT_PUBLIC_LICENSE_API_URL=https://www.goalsguild.com/api

# Stripe secrets are not used by the static landing app.
# Configure Stripe keys in backend SSM parameters instead:
# /goalsguild/<environment>/stripe_secret_key
# /goalsguild/<environment>/stripe_price_id
# /goalsguild/<environment>/stripe_webhook_secret
